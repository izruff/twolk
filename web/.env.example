# Vite only exposes vars prefixed with VITE_ to the client.

# development or production. Selects http (dev) vs https (wss) (prod) for
# the backend connections. Must match ENVIRONMENT in the backend .env.
VITE_ENVIRONMENT=development

# Host (and port) of the frontend-facing REST API.
VITE_REST_API_HOST=localhost:8000

# Host (and port) of the WebRTC signaling backend.
VITE_SIGNALING_SERVER_HOST=localhost:3000
